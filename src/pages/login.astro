---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="私人解盘登录" description="所有者邮箱登录。" noindex={true}>
  <section class="article-shell">
    <p class="eyebrow">OWNER ACCESS</p>
    <h1>私人解盘登录</h1>
    <form id="login-form" class="hero-card">
      <label for="email">所有者邮箱</label>
      <input id="email" name="email" type="email" autocomplete="email" required />
      <button id="submit" type="submit">发送登录链接</button>
      <p id="status" role="status" aria-live="polite"></p>
    </form>
  </section>
</BaseLayout>

<script>
  import { callbackUrl, requestMagicLink } from '../lib/auth';
  import { supabase } from '../lib/supabase';

  const form = document.querySelector<HTMLFormElement>('#login-form');
  const email = document.querySelector<HTMLInputElement>('#email');
  const submit = document.querySelector<HTMLButtonElement>('#submit');
  const status = document.querySelector<HTMLElement>('#status');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!email || !submit || !status) return;
    submit.disabled = true;
    status.textContent = '正在发送登录邮件……';
    const result = await requestMagicLink(
      supabase,
      email.value.trim(),
      callbackUrl(window.location.origin),
    );
    status.textContent = result.message;
    submit.disabled = false;
  });
</script>
